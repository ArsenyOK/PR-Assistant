{
  "name": "pr-assistant",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @pr-assistant/web --filter @pr-assistant/server dev",
    "dev:web": "pnpm --filter @pr-assistant/web dev",
    "dev:server": "pnpm --filter @pr-assistant/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  }
}
